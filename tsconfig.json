{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"]
    },
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["app/**/*", "drizzle/**/*", "*.ts", "*.tsx"],
  "exclude": ["node_modules", ".output", ".vinxi"]
}
